class Solution(object):
    def sortPeople(self, names, heights):
        n = len(heights)
        for i in range(n -1):
            min_ind = i
            for j in range(i+1 , n):
                if heights[min_ind] < heights[j]:
                    min_ind = j
            heights[i] , heights[min_ind] = heights[min_ind] , heights[i]
            names[i] , names[min_ind] = names[min_ind] , names[i]
        return names

