class Solution(object):
    def targetIndices(self, nums, target):
        """
        :type nums: List[int]
        :type target: int
        :rtype: List[int]
        """
        ind = []
        sorted_ = sorted(nums)
        for i in range(len(nums)):
            if  sorted_[i] == target:
                ind.append(i)
        return ind
        
