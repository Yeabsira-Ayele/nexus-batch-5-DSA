class Solution(object):
    def applyOperations(self, nums):
        """
        :type nums: List[int]
        :rtype: List[int]
        """
        newnums =  []
        n = len(nums)
        for i in range(n -1):
            if nums[i] == nums[i + 1]:
                nums[i] =  nums[i] * 2
                nums[i + 1] = 0
        for x in nums:
            if x != 0:
                newnums.append(x )
        while(len(newnums) < n):
            newnums.append(0)
        return  newnums
